# ============================================
# MWP Tools - Environment Variables
# Copy this to .env.local and fill in values
# NEVER commit .env.local to git
# ============================================

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email alerts (for pricing + competitor scraper alerts)
ALERT_EMAIL_TO=matt@milkywaypark.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@milkywaypark.com
SMTP_PASS=your-app-password

# Strava (for client engagement tool)
STRAVA_CLIENT_ID=your-strava-client-id
STRAVA_CLIENT_SECRET=your-strava-client-secret

# Cron secret (protects cron endpoints from unauthorized calls)
CRON_SECRET=generate-a-random-32-char-string-here

# Flybook API (AEX bookings sync)
# Generate a new 'Public' type key in Flybook → API Integrations → Add New
# Header used: X-FB-API-KEY
FLYBOOK_AEX_API_KEY=your-flybook-public-api-key

# Salesforce (TBT bookings sync — Thomson Bike Tours uses Sugati Travel CRM on Salesforce)
#
# REQUIRED — only these 4 values needed:
SF_TBT_INSTANCE_URL=https://thomsonbiketours.my.salesforce.com
SF_TBT_USERNAME=your-salesforce-login-email@domain.com
SF_TBT_PASSWORD=your-salesforce-password
SF_TBT_SECURITY_TOKEN=the-token-emailed-from-sf-settings
#
# HOW TO GET THE SECURITY TOKEN (separate from your password):
#   1. Log into Salesforce
#   2. Click your avatar / name in the top-right corner
#   3. Click "Settings"
#   4. Left sidebar: click "Reset My Security Token"
#   5. Click the button — Salesforce emails the token to you immediately
#   6. Copy that token here as SF_TBT_SECURITY_TOKEN
#
# NOTE: MFA on the Salesforce website does NOT block API auth. These 4 values
# are all you need — no Connected App setup required.
#
# OPTIONAL (only needed if auth fails with "invalid_client" error):
# SF_TBT_CLIENT_ID=your-connected-app-client-id
# SF_TBT_CLIENT_SECRET=your-connected-app-client-secret
